{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "railpack"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyMaxRetries": 10,
    "healthchecks": {
      "readiness": {
        "path": "/",
        "initialDelaySeconds": 30,
        "periodSeconds": 10
      }
    }
  }
}
