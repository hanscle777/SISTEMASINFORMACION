{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "railpack"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "heroku-php-nginx public/",
    "healthchecks": {
      "readiness": {
        "path": "/",
        "initialDelaySeconds": 30
      }
    }
  }
}
